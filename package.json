{
  "name": "aira-sdk",
  "version": "3.0.0",
  "description": "The authorization and audit layer for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./extras/langchain": {
      "types": "./dist/extras/langchain.d.ts",
      "default": "./dist/extras/langchain.js"
    },
    "./extras/vercel-ai": {
      "types": "./dist/extras/vercel-ai.d.ts",
      "default": "./dist/extras/vercel-ai.js"
    },
    "./extras/openai-agents": {
      "types": "./dist/extras/openai-agents.d.ts",
      "default": "./dist/extras/openai-agents.js"
    },
    "./extras/mcp": {
      "types": "./dist/extras/mcp.d.ts",
      "default": "./dist/extras/mcp.js"
    },
    "./extras/webhooks": {
      "types": "./dist/extras/webhooks.d.ts",
      "default": "./dist/extras/webhooks.js"
    },
    "./extras": {
      "types": "./dist/extras/index.d.ts",
      "default": "./dist/extras/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "Aira <sdk@airaproof.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/aira-proof/typescript-sdk"
  },
  "homepage": "https://airaproof.com",
  "keywords": [
    "aira",
    "ai",
    "agents",
    "notarization",
    "compliance",
    "eu-ai-act",
    "cryptographic-receipts",
    "langchain",
    "vercel-ai",
    "openai",
    "mcp"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "ai": ">=3.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
